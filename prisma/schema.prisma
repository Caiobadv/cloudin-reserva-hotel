// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enums nativos — usamos String com validação na aplicação.
// Valores válidos:
//   UserRole:          CLIENT | RECEPTION | ADMIN
//   ReservationStatus: PENDING | CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
//   PaymentStatus:     PENDING | APPROVED | REJECTED

model User {
  id            String            @id @default(uuid())
  name          String
  email         String            @unique
  phone         String
  password      String
  role          String            @default("CLIENT")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reservations  Reservation[]
  checkins      ReceptionCheckin[]
  blockedSlots  BlockedSlot[]
}

model Room {
  id            String            @id @default(uuid())
  name          String
  description   String
  capacity      Int
  pricePerHour  Float
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reservations  Reservation[]
  blockedSlots  BlockedSlot[]
}

model Reservation {
  id            String            @id @default(uuid())
  code          String            @unique
  userId        String
  roomId        String
  date          String            // formato YYYY-MM-DD
  startTime     String            // formato HH:00
  endTime       String            // formato HH:00
  durationHours Int
  totalPrice    Float
  status        String            @default("PENDING")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  room          Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  payment       Payment?
  checkin       ReceptionCheckin?

  @@index([roomId, date, status])
  @@index([userId])
}

model Payment {
  id                    String    @id @default(uuid())
  reservationId         String    @unique
  amount                Float
  method                String    @default("credit_card_simulated")
  status                String    @default("PENDING")
  simulatedCardLast4    String?
  transactionId         String    @unique
  processedAt           DateTime?
  createdAt             DateTime  @default(now())

  reservation           Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ReceptionCheckin {
  id            String            @id @default(uuid())
  reservationId String            @unique
  checkedInBy   String
  checkedInAt   DateTime          @default(now())
  notes         String?
  createdAt     DateTime          @default(now())

  reservation   Reservation       @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [checkedInBy], references: [id], onDelete: Cascade)
}

model BlockedSlot {
  id            String            @id @default(uuid())
  roomId        String
  date          String            // formato YYYY-MM-DD
  startTime     String            // formato HH:00
  endTime       String            // formato HH:00
  reason        String
  blockedBy     String
  createdAt     DateTime          @default(now())

  room          Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [blockedBy], references: [id], onDelete: Cascade)

  @@index([roomId, date])
}
